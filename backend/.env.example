# TaskForge Environment Configuration
# Copy this to .env and adjust values

APP_NAME=TaskForge
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskforge

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Worker settings
WORKER_CONCURRENCY=4
MAX_RETRIES=3
RETRY_BACKOFF=60

# Queue names (usually don't change)
DEFAULT_QUEUE=default
HIGH_PRIORITY_QUEUE=high
LOW_PRIORITY_QUEUE=low
EMAIL_QUEUE=email
ANALYTICS_QUEUE=analytics
